# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---- Build output ----
dist/
dist-ssr/
*.local

# ---- Vite ----
.vite/
# Temp configs Vite writes when loading vite.config.ts (the .mjs leftovers)
vite.config.*.timestamp-*

# ---- Logs ----
# Root-level runtime log output only — must not match source dirs like
# src/views/logs/ (the Audit Logs view lives there).
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Environment files ----
# Ignore ALL env files (including .env.production) except the example.
# .env.production can hold secrets — keep it out of git.
.env
.env.*
!.env.example

# ---- Testing / coverage ----
coverage/
*.lcov
.nyc_output/
cypress/videos/
cypress/screenshots/
/test-results/
/playwright-report/
/playwright/.cache/

# ---- TypeScript ----
*.tsbuildinfo
.tsbuild/
# Compiled output of vite.config.ts must never be committed — it shadows the
# real .ts config and drifts out of sync.
vite.config.js
vite.config.d.ts

# ---- Editor / IDE ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- OS files ----
.DS_Store
Thumbs.db

# ---- Misc ----
*.tgz
.cache/
.temp/
.tmp/

# Deployment build artifacts
deploy/_artifacts/
