# socrate-admin-bff configuration

# ── Phase 1 (always) ─────────────────────────────────────────────────────────
BFF_LISTEN_ADDR=127.0.0.1:8091
BFF_ADMIN_UPSTREAM=http://127.0.0.1:8081

# ── Phase 2 (server-side sessions) ───────────────────────────────────────────
# Setting BFF_CLIENT_ID enables login/session handling. Leave empty for the
# Phase 1 pass-through skeleton. The client_id/secret are a CONFIDENTIAL OAuth
# client held only by the BFF — never in the SPA.
# BFF_CLIENT_ID=admin-console
# BFF_CLIENT_SECRET=
# BFF_OAUTH_UPSTREAM=http://127.0.0.1:8080
# BFF_OAUTH_PUBLIC_URL=https://socrate.vandermoten.eu
# BFF_PUBLIC_ORIGIN=https://admin.vandermoten.eu
# BFF_SCOPES=openid profile email
# BFF_SESSION_IDLE=30m
# BFF_SESSION_ABSOLUTE=8h
# BFF_COOKIE_SECURE=true
