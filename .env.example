# Socrate — Superadmin Portal · Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Socrate API gateway (MUST use https:// in production).
#
# This origin must front BOTH Socrate routers:
#   • the Admin API      — /api/admin/*        (port 8081)
#   • the public OAuth API — /api/auth/*, /api/profile, /oauth/* (port 8080)
# The portal calls admin endpoints plus a few public-API endpoints (login
# refresh, password reset, profile self-service) on the same origin, so deploy
# a reverse proxy that routes both prefixes to the right backend.
#
# Example: https://auth.your-domain.com
VITE_ADMIN_API_URL=https://auth.your-domain.com
