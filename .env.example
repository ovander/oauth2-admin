# OAuth2 Admin Frontend — Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the admin API (MUST use https:// in production)
# Example: https://admin-api.your-domain.com
VITE_ADMIN_API_URL=https://admin-api.your-domain.com
