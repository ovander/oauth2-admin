# Socrate — Superadmin Portal · Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Socrate has TWO origins (they do not overlap):
#   • OIDC issuer  (:8080) — /oauth/*, /api/auth/*, /api/profile, /static/*
#   • Admin API    (:8081) — /api/admin/* only
# So the SPA needs TWO base URLs. In production a single gateway can front both
# (then point both vars at it); in split-port dev they are different ports.

# Admin RESOURCE server — serves /api/admin/* (apps, users, dashboard, security,
# logs, elevate, change-password). Called with `Authorization: Bearer <access>`.
# MUST use https:// in production.
#   • split-port dev:  http://localhost:8081
#   • single gateway:  https://auth.your-domain.com
VITE_ADMIN_API_URL=http://localhost:8081

# ─────────────────────────────────────────────────────────────────────────────
# OAuth / OIDC (Authorization Code + PKCE)
# ─────────────────────────────────────────────────────────────────────────────
# The admin console is a PUBLIC PKCE client. The refresh token is delivered as an
# HttpOnly cookie scoped to the issuer's /oauth/token path (never in JS). See
# go-oauth2 docs/ADMIN-SPA-MIGRATION.md.

# OIDC issuer origin — authorize, token, refresh AND logout (/api/auth/logout)
# all live here (the cookie is set/read here, so refresh and logout must hit it).
# This is the backend's OAUTH_ISSUER. Token/refresh/logout go cross-origin to it,
# so the backend must allow CORS for the SPA origin (ALLOWED_ORIGINS) — it covers
# both ports in one shot. Defaults to VITE_ADMIN_API_URL if unset.
#   • split-port dev:      http://localhost:8080
#   • single gateway/prod: same as VITE_ADMIN_API_URL (leave unset)
VITE_OIDC_ISSUER=http://localhost:8080

# Public client id. MUST equal the backend's ADMIN_CONSOLE_CLIENT_ID (the
# operator sets that env var; Socrate auto-registers this client at startup).
# Defaults to "oauth2-admin" if unset.
VITE_OAUTH_CLIENT_ID=oauth2-admin

# Space-delimited scopes requested at /oauth/authorize.
# Defaults to "openid email profile" if unset (the contract's scope set).
VITE_OAUTH_SCOPES=openid email profile

# App path the AS redirects back to after login. This exact URI
# (origin + path, e.g. https://admin.your-domain.com/auth/callback) MUST be one
# of the backend's ADMIN_CONSOLE_REDIRECT_URIS (exact match). Defaults to
# "/auth/callback" if unset.
VITE_OAUTH_REDIRECT_PATH=/auth/callback
