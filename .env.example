# Socrate — Superadmin Portal · Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Socrate API gateway (MUST use https:// in production).
#
# This origin must front BOTH Socrate routers:
#   • the Admin API      — /api/admin/*        (port 8081)
#   • the public OAuth API — /api/auth/*, /api/profile, /oauth/* (port 8080)
# The portal calls admin endpoints plus a few public-API endpoints (login
# refresh, password reset, profile self-service) on the same origin, so deploy
# a reverse proxy that routes both prefixes to the right backend.
#
# Example: https://auth.your-domain.com
VITE_ADMIN_API_URL=https://auth.your-domain.com

# ─────────────────────────────────────────────────────────────────────────────
# OAuth (Authorization Code + PKCE)
# ─────────────────────────────────────────────────────────────────────────────
# The admin console signs in via Authorization Code + PKCE against the Socrate
# authorization server (/oauth/authorize + /oauth/token). It is a PUBLIC client
# (no secret); the refresh token is delivered as an HttpOnly cookie scoped to
# /oauth/token and never stored in JS. See go-oauth2 docs/ADMIN-SPA-MIGRATION.md.

# OIDC issuer origin — where /oauth/authorize, /oauth/token and the refresh
# grant live. This is the backend's OAUTH_ISSUER. With split-port dev (OAuth on
# :8080, admin API on :8081) point it straight at the issuer so the hosted login
# renders from its own origin (styled, /static assets load) and matches the `iss`
# claim. The token/refresh XHRs go here cross-origin — the backend must allow
# CORS for the SPA origin (ALLOWED_ORIGINS) and the SPA sends credentials for the
# refresh cookie (it already does). Defaults to VITE_ADMIN_API_URL if unset.
#   • split-port dev:      http://localhost:8080
#   • single gateway/prod: same as VITE_ADMIN_API_URL (leave unset)
VITE_OAUTH_ISSUER=http://localhost:8080

# Public client id. MUST equal the backend's ADMIN_CONSOLE_CLIENT_ID (the
# operator sets that env var; Socrate auto-registers this client at startup).
# Defaults to "oauth2-admin" if unset.
VITE_OAUTH_CLIENT_ID=oauth2-admin

# Space-delimited scopes requested at /oauth/authorize.
# Defaults to "openid email profile" if unset (the contract's scope set).
VITE_OAUTH_SCOPES=openid email profile

# App path the AS redirects back to after login. This exact URI
# (origin + path, e.g. https://admin.your-domain.com/auth/callback) MUST be one
# of the backend's ADMIN_CONSOLE_REDIRECT_URIS (exact match). Defaults to
# "/auth/callback" if unset.
VITE_OAUTH_REDIRECT_PATH=/auth/callback
